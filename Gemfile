source "https://rubygems.org"

# Mirrors the gem set GitHub Pages builds with, so local `bundle exec jekyll serve`
# matches production. GitHub builds the site server-side; this is for previewing.
gem "github-pages", group: :jekyll_plugins

# Lockstep with GitHub Pages' Ruby; webrick is no longer bundled with Ruby 3+.
gem "webrick", "~> 1.8"
